diff --git a/hermes_cli/xai_grok_build.py b/hermes_cli/xai_grok_build.py
new file mode 100644
index 000000000..6e400e7c4
--- /dev/null
+++ b/hermes_cli/xai_grok_build.py
@@ -0,0 +1,168 @@
+"""xAI Grok Build / Composer models via cli-chat-proxy.grok.com.
+
+SuperGrok OAuth tokens (``xai-oauth``) work against both ``api.x.ai/v1``
+(dev API models) and ``cli-chat-proxy.grok.com/v1`` (grok-build,
+grok-composer-*).  The proxy requires Grok-CLI identity headers that
+``XAI_API_KEY`` cannot satisfy.
+"""
+
+from __future__ import annotations
+
+import json
+import logging
+import os
+import urllib.request
+from typing import Dict, List, Optional
+
+logger = logging.getLogger(__name__)
+
+DEFAULT_XAI_GROK_BUILD_BASE_URL = "https://cli-chat-proxy.grok.com/v1"
+DEFAULT_GROK_CLIENT_VERSION = "0.2.51"
+
+# Static fallback when live ``/models`` is unreachable (offline picker).
+_XAI_GROK_BUILD_STATIC_FALLBACK: List[str] = [
+    "grok-composer-2.5-fast",
+    "grok-build",
+]
+
+
+def grok_client_version() -> str:
+    return (
+        os.getenv("GROK_CLIENT_VERSION", "").strip()
+        or os.getenv("HERMES_GROK_CLIENT_VERSION", "").strip()
+        or DEFAULT_GROK_CLIENT_VERSION
+    )
+
+
+def is_xai_grok_build_model(model: str) -> bool:
+    """Return True when *model* is served on cli-chat-proxy, not api.x.ai."""
+    mid = str(model or "").strip().lower()
+    if not mid:
+        return False
+    return (
+        mid == "grok-build"
+        or mid.startswith("grok-build-")
+        or mid.startswith("grok-composer-")
+    )
+
+
+def resolve_xai_oauth_inference_base_url(
+    model: str,
+    *,
+    fallback: str,
+) -> str:
+    """Pick api.x.ai vs cli-chat-proxy based on the target model."""
+    if is_xai_grok_build_model(model):
+        override = (
+            os.getenv("GROK_CLI_CHAT_PROXY_BASE_URL", "").strip().rstrip("/")
+            or os.getenv("HERMES_XAI_GROK_BUILD_BASE_URL", "").strip().rstrip("/")
+        )
+        return override or DEFAULT_XAI_GROK_BUILD_BASE_URL
+    return (fallback or "").strip().rstrip("/")
+
+
+def grok_cli_proxy_model_list_headers(access_token: str) -> Dict[str, str]:
+    return {
+        "Authorization": f"Bearer {access_token}",
+        "X-XAI-Token-Auth": "xai-grok-cli",
+        "Accept": "application/json",
+    }
+
+
+def grok_cli_proxy_request_headers(model: str) -> Dict[str, str]:
+    """Per-request headers for cli-chat-proxy inference."""
+    version = grok_client_version()
+    headers = {
+        "X-XAI-Token-Auth": "xai-grok-cli",
+        "x-grok-client-version": version,
+        "User-Agent": f"xai-grok-workspace/{version}",
+    }
+    mid = str(model or "").strip()
+    if mid:
+        headers["x-grok-model-override"] = mid
+    return headers
+
+
+def grok_cli_proxy_default_headers(model: str) -> Dict[str, str]:
+    """Client-level default headers for cli-chat-proxy OpenAI clients."""
+    return grok_cli_proxy_request_headers(model)
+
+
+def fetch_xai_grok_build_models(
+    access_token: str,
+    *,
+    timeout: float = 5.0,
+) -> Optional[List[str]]:
+    """Fetch grok-build / composer model IDs from cli-chat-proxy."""
+    token = str(access_token or "").strip()
+    if not token:
+        return None
+
+    base = (
+        os.getenv("GROK_CLI_CHAT_PROXY_BASE_URL", "").strip().rstrip("/")
+        or os.getenv("HERMES_XAI_GROK_BUILD_BASE_URL", "").strip().rstrip("/")
+        or DEFAULT_XAI_GROK_BUILD_BASE_URL
+    )
+    url = f"{base}/models"
+    req = urllib.request.Request(
+        url,
+        headers=grok_cli_proxy_model_list_headers(token),
+    )
+    try:
+        with urllib.request.urlopen(req, timeout=timeout) as resp:
+            data = json.loads(resp.read().decode())
+        models = data.get("data") if isinstance(data, dict) else None
+        if not isinstance(models, list):
+            return None
+        ids = [str(m.get("id", "")).strip() for m in models if isinstance(m, dict)]
+        ids = [mid for mid in ids if mid]
+        return ids or None
+    except Exception as exc:
+        logger.debug("cli-chat-proxy /models fetch failed: %s", exc)
+        return None
+
+
+def _merge_model_ids(*groups: List[str]) -> List[str]:
+    seen: set[str] = set()
+    merged: List[str] = []
+    for group in groups:
+        for mid in group:
+            if mid and mid not in seen:
+                seen.add(mid)
+                merged.append(mid)
+    return merged
+
+
+def _promote_composer_models(ids: List[str]) -> List[str]:
+    """Pin cli-chat-proxy headline models at the top of the picker."""
+    priority = ("grok-composer-2.5-fast", "grok-build")
+    head = [m for m in priority if m in ids]
+    tail = [m for m in ids if m not in head]
+    return head + tail
+
+
+def get_xai_oauth_model_ids(
+    access_token: Optional[str] = None,
+    *,
+    timeout: float = 5.0,
+) -> List[str]:
+    """Merged catalog: cli-chat-proxy (Composer/Build) + api.x.ai models."""
+    from hermes_cli.models import _xai_curated_models
+
+    api_models = list(_xai_curated_models())
+
+    token = str(access_token or "").strip()
+    if not token:
+        try:
+            from hermes_cli.auth import resolve_xai_oauth_runtime_credentials
+
+            creds = resolve_xai_oauth_runtime_credentials(refresh_if_expiring=True)
+            token = str(creds.get("api_key") or "").strip()
+        except Exception:
+            token = ""
+
+    build_models = fetch_xai_grok_build_models(token, timeout=timeout) if token else None
+    if not build_models:
+        build_models = list(_XAI_GROK_BUILD_STATIC_FALLBACK)
+
+    return _promote_composer_models(_merge_model_ids(build_models, api_models))
