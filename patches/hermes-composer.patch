diff --git a/tests/hermes_cli/test_xai_grok_build.py b/tests/hermes_cli/test_xai_grok_build.py
new file mode 100644
index 000000000..5d4329894
--- /dev/null
+++ b/tests/hermes_cli/test_xai_grok_build.py
@@ -0,0 +1,80 @@
+"""Tests for cli-chat-proxy Grok Build / Composer bridge."""
+
+from hermes_cli.xai_grok_build import (
+    DEFAULT_XAI_GROK_BUILD_BASE_URL,
+    _merge_model_ids,
+    _promote_composer_models,
+    fetch_xai_grok_build_models,
+    get_xai_oauth_model_ids,
+    grok_cli_proxy_request_headers,
+    is_xai_grok_build_model,
+    resolve_xai_oauth_inference_base_url,
+)
+
+
+def test_is_xai_grok_build_model_detects_composer_and_build():
+    assert is_xai_grok_build_model("grok-composer-2.5-fast")
+    assert is_xai_grok_build_model("grok-build")
+    assert is_xai_grok_build_model("grok-build-0.1")
+    assert not is_xai_grok_build_model("grok-4.3")
+    assert not is_xai_grok_build_model("")
+
+
+def test_resolve_xai_oauth_inference_base_url_routes_per_model():
+    api_base = "https://api.x.ai/v1"
+    assert resolve_xai_oauth_inference_base_url(
+        "grok-4.3",
+        fallback=api_base,
+    ) == api_base
+    assert resolve_xai_oauth_inference_base_url(
+        "grok-composer-2.5-fast",
+        fallback=api_base,
+    ) == DEFAULT_XAI_GROK_BUILD_BASE_URL
+
+
+def test_grok_cli_proxy_request_headers_include_version_and_override():
+    headers = grok_cli_proxy_request_headers("grok-composer-2.5-fast")
+    assert headers["X-XAI-Token-Auth"] == "xai-grok-cli"
+    assert headers["x-grok-model-override"] == "grok-composer-2.5-fast"
+    assert "x-grok-client-version" in headers
+    assert headers["User-Agent"].startswith("xai-grok-workspace/")
+
+
+def test_fetch_xai_grok_build_models_parses_openai_shape(monkeypatch):
+    class _Resp:
+        def __enter__(self):
+            return self
+
+        def __exit__(self, *args):
+            return False
+
+        def read(self):
+            return b'{"data":[{"id":"grok-build"},{"id":"grok-composer-2.5-fast"}]}'
+
+    monkeypatch.setattr("urllib.request.urlopen", lambda *a, **k: _Resp())
+
+    models = fetch_xai_grok_build_models("session-token")
+    assert models == ["grok-build", "grok-composer-2.5-fast"]
+
+
+def test_get_xai_oauth_model_ids_merges_build_and_api_catalog(monkeypatch):
+    monkeypatch.setattr(
+        "hermes_cli.models._xai_curated_models",
+        lambda: ["grok-4.3", "grok-4.20-0309-reasoning"],
+    )
+    monkeypatch.setattr(
+        "hermes_cli.xai_grok_build.fetch_xai_grok_build_models",
+        lambda *a, **k: ["grok-build", "grok-composer-2.5-fast"],
+    )
+
+    models = get_xai_oauth_model_ids(access_token="token")
+    assert models[0] == "grok-composer-2.5-fast"
+    assert models[1] == "grok-build"
+    assert "grok-4.3" in models
+
+
+def test_merge_and_promote_helpers():
+    assert _merge_model_ids(["a"], ["b", "a"]) == ["a", "b"]
+    assert _promote_composer_models(
+        ["grok-4.3", "grok-build", "grok-composer-2.5-fast"]
+    ) == ["grok-composer-2.5-fast", "grok-build", "grok-4.3"]
